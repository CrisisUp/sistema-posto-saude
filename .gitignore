*.py[cod]
*$py.class

# Distribuição, empacotamento e builds
*.egg-info/
.installed.cfg
*.egg
MANIFEST
build/
dist/

# Ambientes Virtuais locais (Venv, Poetry, Pipenv)
.venv/
venv/
ENV/
env/
mypy_cache/
.pytest_cache/
.ruff_cache/

# ==============================================================================
# 3. SEGURANÇA, CHAVES E CONFIGURAÇÕES LOCAIS (CRÍTICO)
# ==============================================================================
# Arquivos de variáveis de ambiente locais (nunca trackear chaves de criptografia)
.env
.env.local
.env.*.local

# Chaves privadas e certificados locais
*.pem
*.key
*.pub

# ==============================================================================
# 4. BANCO DE DADOS LOCAL (Dados de teste/Produção local)
# ==============================================================================
# Evita commitar o arquivo do SQLite com dados sensíveis de pacientes
*.db
*.sqlite
*.sqlite3

# ==============================================================================
# 5. IDEs E EDITORES DE CÓDIGO
# ==============================================================================
# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (PyCharm, WebStorm, etc.)
.idea/

# Editor Config
.editorconfig